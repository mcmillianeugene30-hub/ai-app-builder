# ============================================================
# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env.local and fill in your values
# ============================================================

# ------------------------------------------------------------
# DATABASE
# PostgreSQL connection string (Supabase, Railway, Neon, etc.)
# ------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ------------------------------------------------------------
# NEXTAUTH (Auth.js v5)
# Generate secret: openssl rand -base64 32
# ------------------------------------------------------------
AUTH_SECRET="your-random-secret-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional but recommended)
# Create at: https://console.cloud.google.com/
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ------------------------------------------------------------
# STRIPE
# Get keys from: https://dashboard.stripe.com/apikeys
# Use TEST keys for development!
# ------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Price IDs (create in Stripe Dashboard)
# Products > Add Product > Add Price (one-time)
STRIPE_PRICE_100_CREDITS="price_..."
STRIPE_PRICE_300_CREDITS="price_..."
STRIPE_PRICE_700_CREDITS="price_..."

# ------------------------------------------------------------
# AI PROVIDERS (All FREE tiers — your backend cost = $0)
# ------------------------------------------------------------

# OpenRouter: https://openrouter.ai/ (primary)
OPENROUTER_API_KEY="sk-or-..."

# Google Gemini: https://aistudio.google.com/ (fallback #1)
GEMINI_API_KEY="AIza..."

# Groq: https://console.groq.com/ (fallback #2)
GROQ_API_KEY="gsk_..."

# ------------------------------------------------------------
# APP CONFIGURATION
# ------------------------------------------------------------
CREDITS_PER_GENERATION="5"
NEXT_PUBLIC_APP_NAME="AppBuilder"

# Your email address — grants access to the /admin dashboard
ADMIN_EMAIL="you@example.com"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------
# EMAIL (Resend) — optional but recommended
# Sign up free at: https://resend.com (3,000 emails/month free)
# Sends: welcome email on signup, completion/failure alerts
# If not set, email is silently skipped — no crashes.
# ------------------------------------------------------------
RESEND_API_KEY="re_..."
EMAIL_FROM="AppBuilder <no-reply@yourdomain.com>"
